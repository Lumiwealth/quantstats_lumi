# Copy this file to `.env.release.local` and fill with real values.
# Do not commit `.env.release.local`.

# PyPI API token for project `quantstats-lumi`.
# Format: pypi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PYPI_API_TOKEN=

# Optional override if you want a different GitHub repo target.
# Example: Lumiwealth/quantstats_lumi
GITHUB_REPO=Lumiwealth/quantstats_lumi

# Optional GitHub environment name that holds the release secret.
# Must match workflow `environment: pypi`.
GITHUB_ENVIRONMENT=pypi
